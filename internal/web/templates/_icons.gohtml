{{define "ic-star"}}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round" aria-hidden="true"><path d="M12 3.4l2.66 5.4 5.96.86-4.31 4.2 1.02 5.94L12 17.86l-5.33 2.8 1.02-5.94-4.31-4.2 5.96-.86z"/></svg>{{end}}
